{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bash scripts/vercel-build.sh",
  "outputDirectory": "public",
  "functions": {
    "api/main.rs": {
      "runtime": "@vercel/rust@1.3.0",
      "maxDuration": 30,
      "includeFiles": "shell/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/main" }
  ]
}
